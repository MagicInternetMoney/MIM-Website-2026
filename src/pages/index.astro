---
import BaseLayout from "../layouts/BaseLayout.astro";
import LiveDexStats from "../components/LiveDexStats.vue";
import heroImage from "../../assets/hero-mim.png";
import loreImage from "../../assets/lore-mim.jpeg";
import communityImage from "../../assets/high-council.png";
import minionsImage from "../../assets/minions-of-poverty.png";
import headerImage from "../../assets/header-3.png";
import summonImage from "../../assets/summon.jpg";
import apocImage from "../../assets/mim-apoc.jpg";
import yearsImage from "../../assets/84years.jpg";
import proofNamecheap from "../../assets/proof-namecheap-2013.png";
import proofEmails from "../../assets/proof-exchange-emails-2014.jpeg";
import proofBitcointalk from "../../assets/proof-bitcointalk-ann-2014.jpeg";
import proofCmc from "../../assets/proof-cmc-archive-2017.png";
import proofExtra from "../../assets/proof-extra-2014.jpeg";
import originalLogo from "../../assets/original-mim-logo.jpg";

const contract = "89BZ5RU212yKr3iFdJHyn3ZsR37bS4s8TbmVb2yApump";
const communityUrl = "https://twitter.com/i/communities/2026722594808905782";
const soundcloudUrl = "https://soundcloud.com/magicinternetmoney";
const soundcloudEmbedUrl = `https://w.soundcloud.com/player/?url=${encodeURIComponent(soundcloudUrl)}&color=%23f6c64f&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true`;
const pumpUrl = `https://pump.fun/coin/${contract}`;
const socials = [
  { label: "X Community", href: communityUrl },
  { label: "SoundCloud", href: soundcloudUrl },
  { label: "TikTok", href: "https://tiktok.com/ogmagicinternetmoney" },
  { label: "Telegram", href: "https://t.me/ogmagicinternetmoney" },
  { label: "Discord", href: "https://discord.gg/TKRm439axC" },
];
const loreLinks = [
  { label: "Ancient Lore Tomes", href: "https://x.com/mimcoin/status/2048475629923053789" },
  { label: "Original MIM Design", href: "https://web.archive.org/web/20140403185014/http://www.magicinternetmoney.org/" },
  { label: "Bitcoin Talk Announcement", href: "https://web.archive.org/web/20140408162802/https://bitcointalk.org/index.php?topic=464184.0" },
  { label: "Original Reddit Tip Bot", href: "https://www.reddit.com/user/MagicTip/" },
  { label: "Original Plan Spreadsheet", href: "https://docs.google.com/spreadsheets/d/1l6pSrGA9t1eMzZeC9jtdGbuLGp-lMx_vHzfjAL7dCeg/edit?usp=sharing" },
  { label: "2017 CoinMarketCap Archive", href: "https://web.archive.org/web/20171123024206/https://coinmarketcap.com/currencies/magic-internet-money/" },
];
const gallery = [
  { src: minionsImage, alt: "Minions of Poverty MIM meme", class: "sm:col-span-6" },
  { src: headerImage, alt: "Magic Internet Money banner artwork", class: "sm:col-span-6" },
  { src: summonImage, alt: "Summoning Magic Internet Money artwork", class: "sm:col-span-4" },
  { src: apocImage, alt: "Magic Internet Money apocalyptic artwork", class: "sm:col-span-4" },
  { src: communityImage, alt: "Meeting of the high council artwork", class: "sm:col-span-4" },
  { src: yearsImage, alt: "MIM meme portrait", class: "sm:col-span-6 lg:col-span-4" },
];
const proofItems = [
  {
    src: proofNamecheap,
    alt: "Namecheap order summary for magicinternetmoney.org dated December 19, 2013",
    title: "Domain registered in 2013",
    copy: "Namecheap order summary for magicinternetmoney.org, dated December 19, 2013.",
    class: "lg:col-span-5",
  },
  {
    src: proofEmails,
    alt: "Inbox search results showing Magic Internet Money exchange outreach in February and March 2014",
    title: "Exchange outreach in early 2014",
    copy: "Email threads show MIM exchange and market outreach across February and March 2014.",
    class: "lg:col-span-7",
  },
  {
    src: proofBitcointalk,
    alt: "Bitcointalk announcement for Magic Internet Money dated February 13, 2014",
    title: "Bitcointalk announcement",
    copy: "The forum-era announcement identifies MIM as Magic Internet Money and preserves the OG continuation narrative.",
    class: "lg:col-span-7",
  },
  {
    src: proofCmc,
    alt: "Archived CoinMarketCap listing for Magic Internet Money",
    title: "CoinMarketCap archive",
    copy: "Archived CoinMarketCap page lists Magic Internet Money under ticker MIM.",
    class: "lg:col-span-5",
  },
  {
    src: proofExtra,
    alt: "Additional early Magic Internet Money proof image",
    title: "First alt season receipts",
    copy: "Additional preserved proof from the original 2013 and 2014 MIM era.",
    class: "lg:col-span-12",
  },
];
---

<BaseLayout>
  <header class="fixed inset-x-0 top-0 z-30 border-b border-white/15 bg-[#090806]/75 backdrop-blur-xl">
    <div class="mx-auto flex w-full max-w-[1320px] items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
      <a class="inline-flex items-center gap-3 font-black text-mim-ink" href="#top" aria-label="Magic Internet Money home">
        <img class="size-10 rounded-full border border-mim-gold/65 bg-white object-cover" src={originalLogo.src} width={originalLogo.width} height={originalLogo.height} alt="Original Magic Internet Money logo" />
        <span>MIM</span>
      </a>
      <nav class="flex items-center gap-4 overflow-x-auto text-sm font-bold text-mim-paper/70 md:gap-6" aria-label="Primary navigation">
        <a class="hover:text-mim-ink" href="#lore">Lore</a>
        <a class="hover:text-mim-ink" href="#proof">Proof</a>
        <a class="hover:text-mim-ink" href="#buy">Buy</a>
        <a class="hover:text-mim-ink" href="#tokenomics">Tokenomics</a>
        <a class="hover:text-mim-ink" href="#community">Community</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="relative grid min-h-[92svh] items-end overflow-hidden pt-20">
      <img
        class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
        src={heroImage.src}
        width={heroImage.width}
        height={heroImage.height}
        alt="Magic Internet Money illustrated banner"
      />
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(9,8,6,0.88),rgba(9,8,6,0.32)_55%,rgba(9,8,6,0.62)),linear-gradient(0deg,#090806,rgba(9,8,6,0.04)_58%)]"></div>
      <div class="mim-shell pb-[10svh] pt-24">
        <p class="eyebrow">ca: <span class="normal-case tracking-normal text-mim-ink/90">{contract.slice(0, 5)}...{contract.slice(-5)}</span></p>
        <h1 class="max-w-4xl text-[clamp(3.25rem,12vw,8.8rem)] font-black leading-[0.9] text-mim-ink">Magic Internet Money</h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-mim-paper sm:text-xl">
          The early crypto in-joke that became a thesis: code, community, conviction, and internet culture can summon value from thin air.
        </p>
        <div class="mt-6 flex max-w-xl items-center gap-4 rounded-lg border border-white/15 bg-mim-night/70 p-3 backdrop-blur">
          <img class="size-16 rounded-full border border-mim-gold/65 bg-white object-cover" src={originalLogo.src} width={originalLogo.width} height={originalLogo.height} alt="Original Magic Internet Money logo" />
          <div>
            <p class="m-0 text-sm font-black text-mim-gold">Original coin logo</p>
            <p class="m-0 mt-1 text-sm leading-relaxed text-mim-paper/72">The hat-and-rabbit MIM mark from the 2013 and 2014 era.</p>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="button button-primary" href="#buy">Buy MIM</a>
          <a class="button button-secondary" href={pumpUrl} target="_blank" rel="noreferrer">Trade on Pump.fun</a>
          <a class="button button-secondary" href={communityUrl} target="_blank" rel="noreferrer">Join X Community</a>
        </div>
      </div>
    </section>

    <LiveDexStats mode="ticker" client:load />

    <section id="lore" class="mim-section grid items-center gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:gap-14">
      <div>
        <p class="eyebrow">Lore and narrative</p>
        <h2 class="text-4xl font-black leading-none sm:text-6xl lg:text-7xl">The joke was early. The spell was real.</h2>
        <div class="mt-6 grid gap-4 text-base leading-relaxed text-mim-paper/72 sm:text-lg">
          <p>
            Magic Internet Money, or $MIM, began around 2014 as a playful altcoin experiment by Christopher Franko, long before memecoins became a market category.
          </p>
          <p>
            The name nodded at the way skeptics described Bitcoin in the forum era: "What's Bitcoin?" "Magic internet money, bro." MIM leaned into that absurdity and turned it into a banner for crypto's weirdest superpower.
          </p>
          <p>
            It was mineable, whimsical, and deliberately unserious in a scene that often tried very hard to look serious. The point was not only the coin. It was the belief machine: community, code, humor, and culture coordinating in public during the first alt season.
          </p>
        </div>
      </div>
      <figure class="panel overflow-hidden">
        <img
          class="h-[min(620px,76svh)] w-full object-cover"
          src={loreImage.src}
          width={loreImage.width}
          height={loreImage.height}
          alt="Magic Internet Money ATM artwork"
        />
      </figure>
    </section>

    <section id="proof" class="mim-section pt-8">
      <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:gap-14">
        <div>
          <p class="eyebrow">Important historical lore</p>
          <h2 class="text-4xl font-black leading-none sm:text-6xl lg:text-7xl">Original MIM, first alt season.</h2>
          <p class="mt-6 text-base leading-relaxed text-mim-paper/72 sm:text-lg">
            The proof trail points back to 2013 and 2014: the magicinternetmoney.org domain, the Bitcointalk announcement, early exchange outreach, tip-bot activity, planning docs, and the archived CoinMarketCap listing for Magic Internet Money.
          </p>
          <figure class="panel mt-7 overflow-hidden">
            <img class="mx-auto aspect-square max-h-[420px] w-full bg-white object-contain p-4" src={originalLogo.src} width={originalLogo.width} height={originalLogo.height} alt="Original Magic Internet Money rabbit in hat logo" />
            <figcaption class="border-t border-white/15 p-5">
              <h3 class="text-xl font-black">The original MIM design</h3>
              <p class="mt-2 text-sm leading-relaxed text-mim-paper/68">The first Magic Internet Money logo: a rabbit rising out of a magician's hat, wrapped in the original coin seal.</p>
            </figcaption>
          </figure>
          <div class="mt-7 grid gap-2">
            {
              loreLinks.map((link) => (
                <a class="flex min-h-12 items-center justify-between gap-4 rounded-lg border border-white/15 bg-mim-coal px-4 text-sm font-black text-mim-ink transition hover:border-mim-gold/60" href={link.href} target="_blank" rel="noreferrer">
                  <span>{link.label}</span>
                  <span class="text-mim-gold">Open</span>
                </a>
              ))
            }
          </div>
        </div>
        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12">
          {
            proofItems.map((item) => (
              <article class:list={["panel overflow-hidden", item.class]}>
                <img class="h-72 w-full object-cover object-top sm:h-80" src={item.src.src} width={item.src.width} height={item.src.height} alt={item.alt} />
                <div class="p-5">
                  <h3 class="text-xl font-black">{item.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-mim-paper/68">{item.copy}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mim-section" aria-label="Meme gallery">
      <div class="mb-7 max-w-3xl">
        <p class="eyebrow">Meme gallery</p>
        <h2 class="text-4xl font-black leading-none sm:text-6xl">Artifacts from the timeline</h2>
      </div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-12">
        {
          gallery.map((item) => (
            <img
              class:list={[
                "min-h-[260px] w-full rounded-lg border border-white/15 bg-mim-coal object-cover sm:min-h-[240px]",
                item.class,
              ]}
              src={item.src.src}
              width={item.src.width}
              height={item.src.height}
              alt={item.alt}
            />
          ))
        }
      </div>
    </section>

    <LiveDexStats mode="markets" client:load />

    <section id="community" class="mim-section">
      <div class="grid overflow-hidden rounded-lg border border-white/15 bg-mim-coal lg:grid-cols-[0.95fr_1.05fr]">
        <div class="p-6 sm:p-8 lg:p-10">
          <p class="eyebrow">Community</p>
          <h2 class="text-4xl font-black leading-none sm:text-6xl">The timeline is the treasury.</h2>
          <p class="mt-5 text-base leading-relaxed text-mim-paper/72 sm:text-lg">
            MIM belongs to the internet culture that kept crypto strange, playful, and impossible to ignore. Join the community, post the memes, and keep the spell moving.
          </p>
          <div class="mt-7 grid gap-2 sm:grid-cols-2">
            {
              socials.map((social) => (
                <a class="button button-secondary w-full" href={social.href} target="_blank" rel="noreferrer">{social.label}</a>
              ))
            }
          </div>
        </div>
        <img
          class="h-full min-h-[320px] w-full object-cover"
          src={communityImage.src}
          width={communityImage.width}
          height={communityImage.height}
          alt="High council gathered around Magic Internet Money"
        />
      </div>
    </section>

    <section class="mim-section pt-8" aria-label="Magic Internet Money music">
      <div class="mb-7 max-w-3xl">
        <p class="eyebrow">Music</p>
        <h2 class="text-4xl font-black leading-none sm:text-6xl">Magic on SoundCloud</h2>
      </div>
      <div class="overflow-hidden rounded-lg border border-white/15 bg-mim-coal">
        <iframe
          class="block h-[460px] w-full border-0"
          title="Magic Internet Money SoundCloud player"
          allow="autoplay"
          src={soundcloudEmbedUrl}
        ></iframe>
      </div>
    </section>

    <section class="mim-section pt-8">
      <div class="mb-7 max-w-3xl">
        <p class="eyebrow">FAQs</p>
        <h2 class="text-4xl font-black leading-none sm:text-6xl">Common questions</h2>
      </div>
      <div class="grid gap-3">
        <details class="panel" open>
          <summary class="cursor-pointer p-5 font-black">What is MIM?</summary>
          <p class="px-5 pb-5 leading-relaxed text-mim-paper/72">Magic Internet Money is a crypto culture project rooted in an early altcoin experiment and revived as a memetic Solana token.</p>
        </details>
        <details class="panel">
          <summary class="cursor-pointer p-5 font-black">Is this the Abracadabra stablecoin?</summary>
          <p class="px-5 pb-5 leading-relaxed text-mim-paper/72">No. This MIM is Magic Internet Money with contract address {contract}.</p>
        </details>
        <details class="panel">
          <summary class="cursor-pointer p-5 font-black">Where does the live data come from?</summary>
          <p class="px-5 pb-5 leading-relaxed text-mim-paper/72">Market stats and the embedded chart use DexScreener data for the Solana token contract.</p>
        </details>
        <details class="panel">
          <summary class="cursor-pointer p-5 font-black">How often does the site update?</summary>
          <p class="px-5 pb-5 leading-relaxed text-mim-paper/72">The live ticker and tokenomics panel poll for fresh market data every 5 seconds while the page is open.</p>
        </details>
      </div>
    </section>
  </main>

  <footer class="border-t border-white/15 px-4 py-7 text-mim-paper/65 sm:px-6 lg:px-8">
    <div class="mx-auto flex w-full max-w-[1320px] flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <span class="font-black text-mim-ink">Magic Internet Money</span>
      <a class="font-bold hover:text-mim-ink" href="#top">Back to top</a>
    </div>
  </footer>
</BaseLayout>
